# =============================================================================
# ASTERISK (ARI)
# =============================================================================
# Хост Asterisk REST Interface
ARI_HOST=127.0.0.1
# Пароль для доступа к ARI
ARI_PASSWORD=your-ari-password
# Порт Asterisk REST Interface
ARI_PORT=8088
# Пользователь для доступа к ARI
ARI_USER=ari

# =============================================================================
# DOCKER
# =============================================================================
# Пароль для Docker Hub (для избежания лимитов pull)
DOCKER_PASSWORD=your-docker-password
# Пользователь для Docker Hub (для избежания лимитов pull)
DOCKER_USER=your-docker-user

# =============================================================================
# FAIL2BAN
# =============================================================================
# Дополнительные сети/IP для whitelist во всех jail (asterisk, sshd, auth-*), через пробел
FAIL2BAN_IGNOREIP=176.100.0.0/16 194.87.108.130

# =============================================================================
# FIREBASE (FCM)
# =============================================================================
# Путь к JSON ключу сервисного аккаунта Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# =============================================================================
# POSTGRESQL
# =============================================================================
# Название базы данных (хранение push-токенов)
POSTGRES_DB=intercom
# Хост PostgreSQL
POSTGRES_HOST=127.0.0.1
# Пароль для доступа к PostgreSQL
POSTGRES_PASSWORD=your-postgres-password
# Порт PostgreSQL
POSTGRES_PORT=5432
# Пользователь для доступа к PostgreSQL
POSTGRES_USER=postgres

# =============================================================================
# REDIS
# =============================================================================
# Хост Redis (временные токены вызовов)
REDIS_HOST=127.0.0.1
# Пароль для доступа к Redis
REDIS_PASSWORD=your-redis-password
# Порт Redis
REDIS_PORT=6379

# =============================================================================
# SERVER (BACKEND)
# =============================================================================
# Основной домен платформы
SERVER_DOMAIN=your-domain.com
# Публичный IP сервера
SERVER_IP=your-public-ip
# Порт, на котором работает приложение (заводская настройка, переопределять при необходимости)
SERVER_PORT=3000
# Уровень логирования Fastify/Pino (debug, info, warn, error)
LOG_LEVEL=info

# =============================================================================
# MULTIFON (SIP TRUNK)
# =============================================================================
# Номер МультиФон в формате 79XXXXXXXXX (используется в deploy/ADD_MULTIFON.md)
MULTIFON_PHONE=79000000000
# Пароль МультиФон (используется в deploy/ADD_MULTIFON.md)
MULTIFON_PASSWORD=your-multifon-password

# =============================================================================
# TEST ADDRESS (deploy/ADD_ADDRESS.md)
# =============================================================================
# Тестовый адрес для инструкции добавления адреса
TEST_ADDRESS_STREET=Testovaya
TEST_ADDRESS_HOUSE=1
TEST_ADDRESS_BUILDING=
TEST_ADDRESS_LETTER=
TEST_ADDRESS_STRUCTURE=

# =============================================================================
# TEST USER (deploy/ADD_USER.md)
# =============================================================================
# Тестовый пользователь для привязки к адресу/квартире (должен уже существовать после OTP)
TEST_USER_PHONE=79000000000
TEST_USER_ADDRESS_ID=1
TEST_USER_APARTMENT=1

# =============================================================================
# TURN (COTURN)
# =============================================================================
# Пароль для TURN сервера
TURN_PASSWORD=your-turn-password
# Пользователь для TURN сервера
TURN_USER=turn